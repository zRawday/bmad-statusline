{
  "permissions": {},
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "(?:bmad|gds|wds)[:-]",
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.config/bmad-statusline/bmad-hook.js\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.config/bmad-statusline/bmad-hook.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.config/bmad-statusline/bmad-hook.js\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.config/bmad-statusline/bmad-hook.js\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.config/bmad-statusline/bmad-hook.js\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.config/bmad-statusline/bmad-hook.js\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.config/bmad-statusline/bmad-hook.js\""
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.config/bmad-statusline/bmad-hook.js\""
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.config/bmad-statusline/bmad-hook.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.config/bmad-statusline/bmad-hook.js\""
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.config/bmad-statusline/bmad-hook.js\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.config/bmad-statusline/bmad-hook.js\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.config/bmad-statusline/bmad-hook.js\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.config/bmad-statusline/bmad-hook.js\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"~/.config/bmad-statusline/bmad-hook.js\""
          }
        ]
      }
    ]
  }
}
